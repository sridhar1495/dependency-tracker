# ─── Dependency-Track Risk Dashboard — Environment Configuration ──────────────
# Copy this file to .env and fill in your values.
# The install.sh script handles this automatically when run interactively.

# ─── Dashboard ────────────────────────────────────────────────────────────────
# Port the custom risk dashboard is served on (host machine).
DT_DASHBOARD_PORT=3000

# Where nginx proxies /api/* requests — your DependencyTrack API server.
# Use the internal Docker network name if DT runs on the same host,
# or a full URL for an external / remote DT instance.
#   Same host (Docker network): http://dtrack-apiserver:8080   (default)
#   External instance:          https://dtrack.company.com
DT_API_INTERNAL_URL=http://dtrack-apiserver:8080

# Optional: pre-configure the DT API key so the dashboard auto-connects on open.
# Leave blank to require manual entry in the dashboard's "Connect API" modal.
# Generate a key in DT: Administration → Access Management → Teams → API Keys
DT_API_KEY=

# Optional: DependencyTrack UI base URL — enables clickable project links in the
# dashboard table. Leave blank to disable project links.
#   Example: DT_FRONTEND_URL=https://dtrack.company.com
DT_FRONTEND_URL=

# ─── Violation Cache ──────────────────────────────────────────────────────────
# How many hours the violation cache file is considered valid before the service
# auto-rebuilds it. Default is 24 hours.
VIOLATION_CACHE_TTL_HOURS=24
