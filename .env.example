# ─── Dependency-Track Community Edition — Environment Variables ───────────────
# Copy this file to .env and customize before running install.sh

# DependencyTrack version (use 'latest' or pin e.g. '4.11.4')
DT_VERSION=latest

# ─── Ports ────────────────────────────────────────────────────────────────────
DT_FRONTEND_PORT=8080       # DependencyTrack UI
DT_API_PORT=8081            # DependencyTrack REST API
DT_DASHBOARD_PORT=3000      # Custom Risk Dashboard

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=dtrack
POSTGRES_USER=dtrack
POSTGRES_PASSWORD=dtrack_password_change_me   # CHANGE THIS IN PRODUCTION

# ─── DependencyTrack Admin Credentials (used by setup scripts) ────────────────
DT_ADMIN_USER=admin
DT_ADMIN_PASS=admin                           # CHANGE THIS AFTER FIRST LOGIN

# ─── Host / API URLs ──────────────────────────────────────────────────────────
# DT_HOST: hostname or IP used by the BROWSER to reach the API.
# Change to your server's IP or hostname when deploying remotely, e.g.:
#   DT_HOST=192.168.1.100
#   DT_HOST=dtrack.example.com
DT_HOST=localhost

# Internal API URL used by install.sh and management scripts (server-side curl)
DT_API_URL=http://localhost:8081

# ─── Dashboard Auto-connect (optional) ───────────────────────────────────────
# Pre-configure the DependencyTrack API key so the dashboard loads live data
# automatically when the page opens — no "Connect API" click required.
# Leave blank to keep the default manual-connect behaviour.
# The key is exposed to the browser via /dt-config (internal network only).
# Generate a key: Administration → Access Management → Teams → API Keys
DT_API_KEY=

# ─── Dashboard Frontend URL (optional) ───────────────────────────────────────
# The DependencyTrack UI URL used by the dashboard to generate clickable project
# links.  Set this to the URL you open in your browser to access DependencyTrack.
# Leave blank to disable project links (or configure later via the Quick Setup wizard).
# Examples:
#   DT_FRONTEND_URL=http://localhost:8080
#   DT_FRONTEND_URL=https://dtrack.company.com
DT_FRONTEND_URL=

# ─── Dashboard proxy target ───────────────────────────────────────────────────
# The URL that the dashboard's nginx proxy forwards /api/* requests to.
#
#   Local (default): the API container on the same Docker network — do not change.
#     DT_API_INTERNAL_URL=http://dtrack-apiserver:8080
#
#   Production / external instance: set to the full base URL of your DT server.
#     DT_API_INTERNAL_URL=https://dtrack.company.com
#     DT_API_INTERNAL_URL=http://192.168.1.50:8081
#
# After changing this value, restart the dashboard container:
#   docker compose restart dt-dashboard
DT_API_INTERNAL_URL=http://dtrack-apiserver:8080
