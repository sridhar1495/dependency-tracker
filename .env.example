# ─── Dependency-Track Community Edition — Environment Variables ───────────────
# Copy this file to .env and customize before running install.sh

# DependencyTrack version (use 'latest' or pin e.g. '4.11.4')
DT_VERSION=latest

# ─── Ports ────────────────────────────────────────────────────────────────────
DT_FRONTEND_PORT=8080       # DependencyTrack UI
DT_API_PORT=8081            # DependencyTrack REST API
DT_DASHBOARD_PORT=3000      # Custom Risk Dashboard

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=dtrack
POSTGRES_USER=dtrack
POSTGRES_PASSWORD=dtrack_password_change_me   # CHANGE THIS IN PRODUCTION

# ─── DependencyTrack Admin Credentials (used by setup scripts) ────────────────
DT_ADMIN_USER=admin
DT_ADMIN_PASS=admin                           # CHANGE THIS AFTER FIRST LOGIN

# ─── API Base URL (used by scripts) ───────────────────────────────────────────
DT_API_URL=http://localhost:8081
